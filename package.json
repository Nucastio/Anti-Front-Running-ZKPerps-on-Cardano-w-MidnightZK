{
  "name": "anti-frontrunning-zkperps-cardano-midnight",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "contract",
    "midnight-local-cli"
  ],
  "scripts": {
    "postinstall": "bash scripts/fix-libsodium-esm.sh",
    "build:contract": "npm run build -w @zkperps/midnight-contract",
    "build:cli": "tsc -p midnight-local-cli/tsconfig.json",
    "compact": "npm run compact -w @zkperps/midnight-contract",
    "test": "vitest run",
    "bench": "tsx scripts/bench-proofs.ts",
    "bench:srs": "tsx scripts/bench-srs-latency.ts",
    "midnight:deploy": "npm run deploy -w @zkperps/midnight-local-cli",
    "midnight:run-all": "npm run run-all -w @zkperps/midnight-local-cli",
    "midnight:run-pipeline": "npm run run-pipeline -w @zkperps/midnight-local-cli",
    "bench:cardano-emulator": "tsx scripts/bench-cardano-emulator.ts",
    "build:settlement-anchor": "sh -c 'cd cardano/settlement-anchor && aiken build'",
    "pipeline:evidence": "tsx scripts/run-pipeline-evidence.ts",
    "cardano:anchor": "tsx scripts/cardano-anchor-settlement.ts",
    "proof-server": "docker run --rm -p 6300:6300 midnightntwrk/proof-server:8.0.3 midnight-proof-server -v"
  },
  "dependencies": {
    "@lucid-evolution/lucid": "0.4.29",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
}
